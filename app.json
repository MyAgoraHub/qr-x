{
  "expo": {
    "name": "QR-X",
    "slug": "qr-x",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qrx.app",
      "infoPlist": {
        "NSCameraUsageDescription": "QR-X needs camera access to scan QR codes",
        "NSContactsUsageDescription": "QR-X needs contacts access to save contact information from QR codes",
        "NSPhotoLibraryAddUsageDescription": "QR-X needs photo library access to save generated QR codes",
        "NSPhotoLibraryUsageDescription": "QR-X needs photo library access to save and share QR codes",
        "NSLocationWhenInUseUsageDescription": "QR-X uses your location to generate a location QR code."
      }
    },
    "android": {
      "package": "com.qrx.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F1A"
      },
      "edgeToEdgeEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_CONTACTS",
        "WRITE_CONTACTS",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F0F1A"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow QR-X to access your camera to scan QR codes.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow QR-X to access your photos to save QR codes.",
          "savePhotosPermission": "Allow QR-X to save QR codes to your photo library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-contacts",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "QR-X uses your location to generate a location QR code."
        }
      ]
    ],
    "extra": {
      "isBeta": true,
      "environment": "preview",
      "eas": {
        "projectId": "4604bf63-90c0-487d-a2c8-981a900ab562"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "bitfox-worx"
  }
}
